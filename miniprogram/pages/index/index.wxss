/* pages/index/index.wxss - 优化版 */

.container {
  padding: 0;
  padding-bottom: 20rpx;
}

/* 骨架屏 */
.skeleton-wrapper {
  padding: 20rpx;
}

.skeleton-header {
  height: 300rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-quick-chat {
  height: 120rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
  border-radius: 16rpx;
  margin: -40rpx 20rpx 20rpx;
}

.skeleton-section {
  margin: 30rpx 0;
}

.skeleton-item {
  height: 140rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

/* 顶部欢迎区 */
.header {
  position: relative;
  height: 300rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  overflow: hidden;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header-content {
  position: relative;
  z-index: 2;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快速咨询 */
.quick-chat {
  margin: -40rpx 20rpx 20rpx;
  position: relative;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quick-chat-left {
  display: flex;
  align-items: center;
}

.quick-chat-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-chat-text {
  display: flex;
  flex-direction: column;
}

.quick-chat-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.quick-chat-desc {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}

/* 功能板块 */
.section {
  margin: 30rpx 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.boards {
  display: flex;
  flex-direction: column;
}

.board-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.board-icon {
  width: 100rpx;
  height: 100rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.board-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.board-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.board-desc {
  font-size: 24rpx;
  color: #999;
}

/* 热门问题 */
.hot-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.question-tag {
  background-color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
  transition: all 0.3s;
}

.question-tag:active {
  background-color: #f5f5f5;
  transform: scale(0.98);
}

/* 底部声明 */
.footer {
  margin-top: 60rpx;
  padding: 40rpx 20rpx;
  text-align: center;
}

.disclaimer {
  font-size: 24rpx;
  color: #999;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}
