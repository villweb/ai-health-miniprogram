<!--pages/chat/chat.wxml - 修复版（移除图片）-->
<view class="container">
  <!-- 消息列表 -->
  <scroll-view 
    class="message-list" 
    scroll-y 
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
  >
    <view 
      wx:for="{{messages}}" 
      wx:key="id"
      id="msg-{{index}}"
      class="message-item fade-in"
    >
      <!-- 用户消息 -->
      <view class="msg-user" wx:if="{{item.role === 'user'}}">
        <view class="msg-content user-msg">
          <text>{{item.content}}</text>
        </view>
        <view class="avatar user-avatar">👤</view>
      </view>

      <!-- AI 消息 -->
      <view class="msg-ai" wx:else>
        <view class="avatar ai-avatar">🤖</view>
        <view class="msg-content ai-msg">
          <text class="answer-text">{{item.content}}</text>
          
          <!-- 图片 -->
          <view class="images" wx:if="{{item.images.length > 0}}">
            <image 
              wx:for="{{item.images}}" 
              wx:for-item="img"
              wx:key="index"
              src="{{img}}" 
              class="answer-image"
              mode="widthFix"
              bindtap="previewImage"
              data-url="{{img}}"
            ></image>
          </view>
          
          <!-- 商品推荐 -->
          <view class="products" wx:if="{{item.products.length > 0}}">
            <view class="products-title">💡 相关推荐</view>
            <view 
              class="product-card"
              wx:for="{{item.products}}"
              wx:for-item="product"
              wx:key="id"
              bindtap="goToProduct"
              data-product="{{product}}"
            >
              <view class="product-image">🛍️</view>
              <view class="product-info">
                <text class="product-name">{{product.name}}</text>
                <text class="product-desc">{{product.description}}</text>
                <text class="product-price">¥{{product.price}}</text>
              </view>
            </view>
          </view>
          
          <!-- 免责声明 -->
          <text class="disclaimer">💡 仅供参考，不替代医疗建议</text>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{messages.length === 0}}">
      <view class="empty-image">💬</view>
      <text class="empty-text">有什么健康问题想问我？</text>
      <text class="empty-hint">例如：最近总是失眠怎么办？</text>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <input 
      class="input-field"
      bindconfirm="sendMessage"
      bindinput="onInput"
      value="{{inputText}}"
      placeholder="输入您的问题..."
      confirm-type="send"
      adjust-position="{{true}}"
    />
    <button 
      class="send-btn {{inputText ? 'active' : ''}}" 
      bindtap="sendMessage"
      disabled="{{!inputText || sending}}"
    >
      {{sending ? '发送中' : '发送'}}
    </button>
  </view>
</view>
