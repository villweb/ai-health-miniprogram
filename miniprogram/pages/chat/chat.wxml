<!--pages/chat/chat.wxml-->
<view class="chat-container">
  <!-- 消息列表 -->
  <scroll-view 
    class="message-list" 
    scroll-y 
    scroll-top="{{scrollTop}}"
    scroll-with-animation
  >
    <view wx:for="{{messages}}" wx:key="id" class="message-item {{item.type}}">
      
      <!-- 用户消息 -->
      <view wx:if="{{item.type === 'user'}}" class="user-message">
        <view class="message-bubble">
          <text>{{item.content}}</text>
        </view>
      </view>

      <!-- AI 消息 -->
      <view wx:elif="{{item.type === 'ai'}}" class="ai-message">
        <view class="ai-avatar">🐱</view>
        <view class="message-content">
          <!-- 文字回答 -->
          <view class="message-bubble">
            <text>{{item.content}}</text>
            <view class="message-actions">
              <text class="action-btn" bindtap="copyMessage" data-content="{{item.content}}">
                📋 复制
              </text>
            </view>
          </view>

          <!-- 配图展示 -->
          <view wx:if="{{item.images.length > 0}}" class="image-container">
            <view 
              wx:for="{{item.images}}" 
              wx:for-item="image" 
              wx:key="url" 
              class="image-item"
            >
              <image 
                src="{{image.url}}" 
                mode="aspectFit"
                bindtap="previewImage"
                data-url="{{image.url}}"
              />
              <text class="image-caption">{{image.caption}}</text>
            </view>
          </view>

          <!-- 商品推荐卡片 -->
          <view wx:if="{{item.products.length > 0}}" class="products-container">
            <view class="products-title">🎁 相关推荐</view>
            <view 
              wx:for="{{item.products}}" 
              wx:for-item="product" 
              wx:key="id" 
              class="product-card"
              bindtap="goToProduct"
              data-product="{{product}}"
            >
              <image src="{{product.image}}" class="product-image" mode="aspectFill"/>
              <view class="product-info">
                <text class="product-name">{{product.name}}</text>
                <text class="product-price">¥{{product.price}}</text>
              </view>
              <view class="product-action">
                <text>去购买 →</text>
              </view>
            </view>
          </view>

          <!-- 时间戳 -->
          <text class="message-time">{{item.timestamp}}</text>
        </view>
      </view>

      <!-- 错误消息 -->
      <view wx:elif="{{item.type === 'error'}}" class="error-message">
        <view class="message-bubble error">
          <text>❌ {{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-message">
      <view class="ai-avatar">🐱</view>
      <view class="loading-dots">
        <text>.</text>
        <text>.</text>
        <text>.</text>
      </view>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-container">
    <input 
      class="message-input"
      type="text"
      placeholder="请输入您的健康问题..."
      value="{{inputValue}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="sendQuestion"
    />
    <button 
      class="send-button {{inputValue ? 'active' : ''}}"
      bindtap="sendQuestion"
      disabled="{{loading || !inputValue}}"
    >
      发送
    </button>
  </view>
</view>
